#!/bin/sh

changed_files="$(git diff --cached --name-only --diff-filter=ACMR)"

has_version=0

for file in $changed_files; do
    case "$file" in
        VERSION|CHANGELOG.md|app/release_info.json)
            has_version=1
            ;;
    esac
done

if [ "$has_version" = "1" ]; then
    if command -v python >/dev/null 2>&1; then
        PYTHON_CMD="python"
    elif command -v py >/dev/null 2>&1; then
        PYTHON_CMD="py -3"
    else
        echo "Python не найден, не могу синхронизировать app/release_info.json."
        exit 1
    fi

    $PYTHON_CMD scripts/bump_version.py --sync-only || exit 1
    git add app/release_info.json
fi

exit 0
